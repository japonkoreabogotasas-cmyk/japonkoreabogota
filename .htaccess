<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Canonical de host (www), excepto dominio temporal de Railway
RewriteCond %{HTTP_HOST} !\.up\.railway\.app$ [NC]
RewriteCond %{HTTP_HOST} !^www\.japonkoreabogota\.com$ [NC]
RewriteRule ^ https://www.japonkoreabogota.com%{REQUEST_URI} [L,R=301]

# Canonical de protocolo (compatible con reverse proxy), excepto Railway preview
RewriteCond %{HTTP_HOST} !\.up\.railway\.app$ [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://www.japonkoreabogota.com%{REQUEST_URI} [L,R=301]

# Consolidación de URLs antiguas al nuevo sitio
RewriteRule ^pag_compras_/?$ /#purchase-flow [L,R=301,NE]
RewriteRule ^pag_formas_pago_/?$ /#secure-payments [L,R=301,NE]
RewriteRule ^pag_cotizador(?:_en_linea)?/?$ /#support-team [L,R=301,NE]
RewriteRule ^pag_promociones_mant/?$ / [L,R=301]
RewriteRule ^pag_tienda_mant/?$ / [L,R=301]

# URL limpia de políticas (sin extensión) hacia URL canónica
RewriteRule ^pag_politica_seguridad_y_privacidad/?$ /pag_politica_seguridad_y_privacidad.html [L,R=301]
</IfModule>

<IfModule mod_headers.c>
Header always set Content-Security-Policy "upgrade-insecure-requests;"
</IfModule>

ErrorDocument 404 /404.html

# Redirecciones 301 - URLs legacy
RewriteRule ^pag_compras_\.html$ / [R=301,L]
RewriteRule ^pag_formas_pago_\.html$ / [R=301,L]
RewriteRule ^pag_cotizador\.html$ / [R=301,L]
RewriteRule ^pag_promociones_mant\.html$ / [R=301,L]
RewriteRule ^pag_tienda_mant\.html$ / [R=301,L]
RewriteRule ^promociones\.html$ / [R=301,L]
RewriteRule ^tienda-en-linea\.html$ / [R=301,L]
RewriteRule ^store\.html$ / [R=301,L]
