/* ====================================================== */
/* FICHAS AUTOPARTES - DISEÑO MODERNO Y PULCRO           */
/* Japón Korea Bogotá - Versión Premium                  */
/* ====================================================== */

/* CONTENEDOR PRINCIPAL */
.seccion-autopartes {
    background: linear-gradient(135deg, #fef9f5 0%, #ffffff 100%);
    padding: 70px 0;
    position: relative;
}

/* TÍTULO DE SECCIÓN */
.seccion-autopartes .titulo-seccion {
    text-align: center;
    margin-bottom: 50px;
}

.seccion-autopartes .titulo-seccion h2 {
    font-size: 36px;
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 15px;
    position: relative;
    display: inline-block;
}

.seccion-autopartes .titulo-seccion h2:after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, #a40f00, #ffb000);
    border-radius: 2px;
}

.seccion-autopartes .titulo-seccion p {
    font-size: 18px;
    color: #666;
    margin-top: 20px;
}

/* GRID DE FICHAS */
.grid-fichas {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 20px;
}

/* TARJETA INDIVIDUAL */
.ficha-autoparte {
    background: #ffffff;
    border-radius: 24px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.05);
    position: relative;
}

.ficha-autoparte:hover {
    transform: translateY(-10px);
    box-shadow: 0 25px 45px rgba(164, 15, 0, 0.12);
    border-color: rgba(164, 15, 0, 0.15);
}

/* BORDE SUPERIOR DECORATIVO */
.ficha-autoparte:before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #a40f00, #ffb000, #a40f00);
    transform: scaleX(0);
    transition: transform 0.5s ease;
    transform-origin: left;
}

.ficha-autoparte:hover:before {
    transform: scaleX(1);
}

/* CONTENIDO INTERNO */
.ficha-contenido {
    padding: 35px 25px 40px;
    text-align: center;
}

/* CATEGORÍA */
.ficha-categoria {
    font-size: 26px;
    font-weight: 800;
    color: #a40f00;
    margin-bottom: 20px;
    letter-spacing: -0.3px;
    position: relative;
    display: inline-block;
}

.ficha-categoria span {
    position: relative;
    z-index: 1;
}

/* ICONO DECORATIVO */
.ficha-icono {
    width: 70px;
    height: 70px;
    margin: 0 auto 20px;
    background: linear-gradient(135deg, #fff5f0, #ffffff);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(164, 15, 0, 0.1);
}

.ficha-icono i {
    font-size: 32px;
    color: #a40f00;
}

/* IMAGEN */
.ficha-imagen {
    margin: 20px 0;
    min-height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.ficha-imagen img {
    max-width: 130px;
    height: auto;
    transition: transform 0.4s ease;
    filter: drop-shadow(0 5px 10px rgba(0,0,0,0.05));
}

.ficha-autoparte:hover .ficha-imagen img {
    transform: scale(1.08);
}

/* DESCRIPCIÓN */
.ficha-descripcion {
    font-size: 14px;
    line-height: 1.6;
    color: #4a4a4a;
    margin: 20px 0 25px;
    text-align: center;
    font-weight: 500;
}

/* BOTÓN COTIZAR */
.ficha-boton-cotizar {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 28px;
    background: transparent;
    border: 2px solid #a40f00;
    color: #a40f00;
    border-radius: 40px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
}

.ficha-boton-cotizar i {
    font-size: 14px;
    transition: transform 0.3s ease;
}

.ficha-boton-cotizar:hover {
    background: #a40f00;
    color: #ffffff;
    text-decoration: none;
    transform: translateX(5px);
}

.ficha-boton-cotizar:hover i {
    transform: translateX(3px);
}

/* ========== RESPONSIVE ========== */

@media (min-width: 1440px) {
    .grid-fichas {
        max-width: 1400px;
        gap: 35px;
    }
    
    .ficha-categoria {
        font-size: 28px;
    }
    
    .ficha-imagen img {
        max-width: 150px;
    }
    
    .ficha-descripcion {
        font-size: 15px;
    }
}

@media (max-width: 1024px) {
    .grid-fichas {
        gap: 25px;
        padding: 0 15px;
    }
    
    .ficha-contenido {
        padding: 28px 20px 32px;
    }
    
    .ficha-categoria {
        font-size: 24px;
    }
    
    .ficha-imagen img {
        max-width: 115px;
    }
}

@media (max-width: 768px) {
    .seccion-autopartes {
        padding: 50px 0;
    }
    
    .seccion-autopartes .titulo-seccion h2 {
        font-size: 28px;
    }
    
    .grid-fichas {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }
    
    .ficha-contenido {
        padding: 25px 15px 28px;
    }
    
    .ficha-categoria {
        font-size: 20px;
    }
    
    .ficha-imagen img {
        max-width: 100px;
    }
    
    .ficha-descripcion {
        font-size: 12px;
    }
    
    .ficha-boton-cotizar {
        padding: 8px 20px;
        font-size: 12px;
    }
}

@media (max-width: 480px) {
    .grid-fichas {
        grid-template-columns: 1fr;
        gap: 20px;
        padding: 0 15px;
    }
    
    .ficha-categoria {
        font-size: 22px;
    }
    
    .ficha-imagen img {
        max-width: 110px;
    }
}

/* ANIMACIÓN DE ENTRADA */
@keyframes fadeUp {
    from {
        opacity: 0;
        transform: translateY(40px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.ficha-autoparte {
    animation: fadeUp 0.6s ease forwards;
    opacity: 0;
}

.ficha-autoparte:nth-child(1) { animation-delay: 0.05s; }
.ficha-autoparte:nth-child(2) { animation-delay: 0.1s; }
.ficha-autoparte:nth-child(3) { animation-delay: 0.15s; }
.ficha-autoparte:nth-child(4) { animation-delay: 0.2s; }
.ficha-autoparte:nth-child(5) { animation-delay: 0.25s; }
.ficha-autoparte:nth-child(6) { animation-delay: 0.3s; }

