/* ====================================================== */
/* NUESTRAS MARCAS - COMPONENTE ÉPICO                    */
/* Grid responsivo | Efectos hover | Diseño premium       */
/* ====================================================== */

.marcas-section {
    width: 100%;
    padding: 60px 0;
    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    margin: 40px 0;
}

.marcas-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 30px;
}

.marcas-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 15px;
}

.marcas-linea {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, #1a2a4f, #c00000);
    border-radius: 2px;
}

.marcas-titulo {
    font-size: 32px;
    font-weight: 800;
    color: #1a2a4f;
    margin: 0;
    letter-spacing: -0.5px;
}

.marcas-subtitulo {
    text-align: center;
    font-size: 15px;
    color: #666;
    margin-bottom: 50px;
    font-weight: 400;
}

.marcas-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 30px;
}

.marca-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 25px 15px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    cursor: pointer;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 5px 15px rgba(0,0,0,0.02);
}

.marca-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 35px rgba(0,0,0,0.1);
    border-color: rgba(192,0,0,0.2);
}

.marca-logo-wrapper {
    position: relative;
    overflow: visible;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80px;
}

.marca-logo {
    max-width: 100px;
    max-height: 70px;
    width: auto;
    height: auto;
    transition: transform 0.4s ease;
    filter: grayscale(0%);
}

.marca-card:hover .marca-logo {
}

.marca-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(192,0,0,0.1), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 12px;
}

.marca-card:hover .marca-overlay {
    opacity: 1;
}

.marca-nombre {
    font-size: 12.2px;
    font-weight: 600;
    color: #333;
    display: block;
    transition: color 0.3s ease;
    letter-spacing: 0.5px;
}

.marca-card:hover .marca-nombre {
    color: #c00000;
}

/* Responsive */
@media (max-width: 1200px) {
    .marcas-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
    }
}

@media (max-width: 992px) {
    .marcas-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }
    .marcas-titulo {
        font-size: 28px;
    }
}

@media (max-width: 768px) {
    .marcas-section {
        padding: 40px 0;
    }
    .marcas-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
    }
    .marcas-titulo {
        font-size: 20px;
    }
    .marcas-linea {
        width: 40px;
    }
    .marca-card {
        padding: 18px 12px;
    }
    .marca-logo {
        max-width: 80px;
        max-height: 55px;
    }
    .marca-nombre {
        font-size: 12.2px;
    }
}

@media (max-width: 480px) {
    .marcas-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }
    .marca-logo {
        max-width: 65px;
        max-height: 45px;
    }
}

/* Animación de entrada */
@keyframes marcaFadeIn {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.marca-card {
    animation: marcaFadeIn 0.5s ease forwards;
    opacity: 0;
}

.marca-card:nth-child(1) { animation-delay: 0.05s; }
.marca-card:nth-child(2) { animation-delay: 0.1s; }
.marca-card:nth-child(3) { animation-delay: 0.15s; }
.marca-card:nth-child(4) { animation-delay: 0.2s; }
.marca-card:nth-child(5) { animation-delay: 0.25s; }
.marca-card:nth-child(6) { animation-delay: 0.3s; }
.marca-card:nth-child(7) { animation-delay: 0.35s; }
.marca-card:nth-child(8) { animation-delay: 0.4s; }
.marca-card:nth-child(9) { animation-delay: 0.45s; }
.marca-card:nth-child(10) { animation-delay: 0.5s; }
.marca-card:nth-child(11) { animation-delay: 0.55s; }
.marca-card:nth-child(12) { animation-delay: 0.6s; }

