    color: #1a2a4f;
    text-transform: uppercase;
    letter-spacing: 4px;
    margin-bottom: 20px;
    display: inline-block;
}

.slide-title {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    color: white;
    line-height: 1.15;
