/* CONTENEDOR PRINCIPAL */
.scroll-story {
    width: 100%;
    position: relative;
    background: #0a0a0a;
}

/* STICKY CONTAINER */
.scroll-story-sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    overflow: visible !important;
}

/* WRAPPER HORIZONTAL */
.scroll-story-wrapper {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.1s linear;
    will-change: transform;
}

/* SLIDES */
.scroll-story-slide {
    flex: 0 0 100%;
