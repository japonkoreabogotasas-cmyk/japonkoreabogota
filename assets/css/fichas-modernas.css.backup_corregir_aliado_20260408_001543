/* ====================================================== */
/* COMPONENTE AUTOPARTES - CONGRUENTE Y SIMÉTRICO        */
/* Diseño uniforme | Imágenes no afectan márgenes        */
/* ====================================================== */

/* CONTENEDOR PRINCIPAL */
.seccion-autopartes {
    width: 100%;
    padding: 30px 0;
    background: #ffffff;
}

/* TÍTULO */
.titulo-seccion {
    text-align: center;
    margin-bottom: 15px;
}

.titulo-seccion h2 {
    font-size: 28px;
    font-weight: 700;
    color: #1a2a4f;
    margin-bottom: 10px;
}

.titulo-seccion p {
    font-size: 12.2px;
    color: #666;
}

/* GRID - 3 COLUMNAS SIMÉTRICAS */
.grid-fichas {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

/* TARJETAS UNIFORMES */
.ficha-autoparte {
    background: #ffffff;
    border-radius: 12px;
    border: 1px solid #e5e5e5;
    transition: all 0.3s ease;
    position: relative;
}

.ficha-autoparte:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    border-color: #1a2a4f;
}

/* CONTENIDO - ESPACIADO UNIFORME */
.ficha-contenido {
    padding: 16px 12px;
    text-align: center;
}

/* CATEGORÍA - TAMAÑO UNIFORME */
.ficha-categoria {
    font-size: 18px;
    font-weight: 700;
    color: #1a2a4f;
    margin-bottom: 10px;
}

/* IMAGEN - NO AFECTA MÁRGENES */
.ficha-imagen {
    margin: 8px 0;
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

.ficha-imagen img {
    max-width: 130px;
    max-height: 130px;
    width: auto;
    height: auto;
    transition: transform 0.3s ease;
}

/* MOTOR - 24% MÁS GRANDE (SOLO ESCALA, NO AFECTA MÁRGENES) */
    overflow: visible;
}

/* HOVER GENERAL */
.ficha-autoparte:hover .ficha-imagen img {
}

/* DESCRIPCIÓN - SOLO VISIBLE EN HOVER */
.ficha-descripcion {
    font-size: 12.2px;
    line-height: 1.4;
    color: #1a2a4f;
    text-align: justify;
    padding: 8px 10px;
    background: #ffffff;
    border-radius: 8px;
    position: relative;
    z-index: 20;
    opacity: 0;
    max-height: 0;
    overflow: visible !important;
    transition: all 0.3s ease;
    margin: 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.ficha-autoparte:hover .ficha-descripcion {
    opacity: 1;
    max-height: 100px;
    margin: 8px 0;
}

/* BOTÓN */
.ficha-boton-cotizar {
    display: inline-block;
    padding: 6px 16px;
    background: transparent;
    border: 1px solid #1a2a4f;
    color: #1a2a4f;
    border-radius: 30px;
    font-size: 12.2px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
}

.ficha-autoparte:hover .ficha-boton-cotizar {
    background: #1a2a4f;
    color: #ffffff;
}

/* ========== RESPONSIVE ========== */
@media (max-width: 991px) {
    .grid-fichas {
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        padding: 0 15px;
    }
}

@media (max-width: 767px) {
    .grid-fichas {
        grid-template-columns: 1fr;
        gap: 8px;
        padding: 0 15px;
    }
    
    .ficha-imagen img {
        max-width: 120px;
        max-height: 120px;
    }
}

