/* ====================================================== */
/* EQUIPO COMERCIAL - COMPONENTE ANIMADO                 */
/* Líneas delgadas | Fades | Hovers elegantes            */
/* ====================================================== */

.equipo-comercial {
    width: 100%;
    padding: 15px 0 23px 0;
    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    margin: 30px 0;
}

.equipo-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

.equipo-banner {
    text-align: center;
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
}

.equipo-linea-decorativa {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #1a2a4f, #1a2a4f, transparent);
    opacity: 0.6;
}

.equipo-titulo {
    font-size: 28px;
    font-weight: 700;
    color: #1a2a4f;
    letter-spacing: -0.5px;
    margin: 0;
}

.equipo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
    margin-bottom: 40px;
}

.equipo-tarjeta {
    background: #ffffff;
    padding: 30px 20px;
    text-align: center;
    border-radius: 16px;
    transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    position: relative;
    overflow: visible !important;
    box-shadow: 0 5px 15px rgba(0,0,0,0.03);
    border: 1px solid rgba(26, 42, 79, 0.08);
}

.equipo-tarjeta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(26, 42, 79, 0.02), rgba(26, 42, 79, 0.05));
    opacity: 0;
    transition: opacity 0.4s ease;
}

.equipo-tarjeta:hover::before {
    opacity: 1;
}

.equipo-tarjeta:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 35px rgba(26, 42, 79, 0.1);
    border-color: rgba(26, 42, 79, 0.15);
}

.equipo-icono {
    width: 65px;
    height: 65px;
    margin: 0 auto 20px;
    background: #ffffff !important;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.equipo-icono i {
    font-size: 28px;
    color: #1a2a4f;
    transition: all 0.3s ease;
}

.equipo-tarjeta:hover .equipo-icono {
    background: #1a2a4f;
}

.equipo-tarjeta:hover .equipo-icono i {
    color: #ffffff;
}

.equipo-nombre {
    font-size: 18px;
    font-weight: 700;
    color: #1a2a4f;
    margin-bottom: 12px;
    transition: color 0.3s ease;
}

.equipo-tarjeta:hover .equipo-nombre {
    color: #a40f00;
}

.equipo-descripcion {
    font-size: 13px;
    line-height: 1.5;
    color: #666;
    margin: 0;
    transition: color 0.3s ease;
}

.equipo-tarjeta:hover .equipo-descripcion {
    color: #444;
}

.equipo-hover-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: linear-gradient(90deg, #1a2a4f, #a40f00);
    transition: width 0.4s ease;
}

.equipo-tarjeta:hover .equipo-hover-line {
    width: 100%;
}

.equipo-footer {
    text-align: center;
    padding-top: 20px;
    border-top: 1px solid rgba(26, 42, 79, 0.1);
}

.equipo-footer p {
    font-size: 12.2px;
    color: #555;
    margin: 0;
}

@media (max-width: 992px) {
    .equipo-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }
    .equipo-titulo {
        font-size: 20px;
    }
    .equipo-linea-decorativa {
        width: 40px;
    }
}

@media (max-width: 576px) {
    .equipo-grid {
        grid-template-columns: 1fr;
        gap: 8px;
    }
    .equipo-comercial {
        padding: 30px 0;
    }
    .equipo-titulo {
        font-size: 20px;
    }
    .equipo-linea-decorativa {
        width: 30px;
    }
}

/* ====================================================== */
/* EQUIPO COMERCIAL DEFINITIVO - IMAGEN + TEXTOS         */
/* Distanciamiento entre frases | Efectos hover          */
/* ====================================================== */

.equipo-definitivo {
    width: 100%;
    padding: 60px 0;
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
}

.equipo-def-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 30px;
    display: flex;
    flex-direction: column;
    gap: 30px;
}

/* BLOQUE IMAGEN */
.equipo-def-imagen {
    width: 100%;
    border-radius: 24px;
    overflow: visible !important;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
}

.equipo-img-wrapper {
    position: relative;
    overflow: visible !important;
    border-radius: 24px;
}

.equipo-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.9, 0.4, 1.1);
}

/* Hover en imagen - zoom sutil */
.equipo-img-wrapper:hover .equipo-img {
}

/* Overlay al hover */
.equipo-img-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(26, 42, 79, 0.15), rgba(26, 42, 79, 0.05));
    opacity: 0;
    transition: opacity 0.4s ease;
}

.equipo-img-wrapper:hover .equipo-img-overlay {
    opacity: 1;
}

/* BLOQUE TEXTOS */
.equipo-def-textos {
    display: flex;
    flex-direction: column;
    gap: 35px; /* Distanciamiento entre frases */
}

/* Cada frase */
.equipo-def-frase {
    background: #ffffff;
    border-radius: 20px;
    padding: 28px 35px;
    position: relative;
    transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    border: 1px solid rgba(26, 42, 79, 0.08);
    box-shadow: 0 8px 20px rgba(0,0,0,0.03);
}

/* Hover en frases */
.equipo-def-frase:hover {
    transform: translateX(10px);
    border-color: rgba(26, 42, 79, 0.15);
    box-shadow: 0 15px 30px rgba(26, 42, 79, 0.08);
}

/* Icono */
.equipo-def-icono {
    position: absolute;
    top: -15px;
    left: 30px;
    width: 45px;
    height: 45px;
    background: #1a2a4f;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    box-shadow: 0 5px 12px rgba(0,0,0,0.1);
}

.equipo-def-icono i {
    font-size: 22px;
    color: #ffffff;
    transition: transform 0.3s ease;
}

.equipo-def-frase:hover .equipo-def-icono {
    background: #a40f00;
}

.equipo-def-frase:hover .equipo-def-icono i {
    transform: rotate(5deg);
}

/* Texto */
.equipo-def-texto {
    font-size: 16px;
    line-height: 1.6;
    color: #333;
    margin: 0;
    font-style: italic;
    font-weight: 450;
}

/* Línea decorativa hover */
.equipo-def-linea {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: linear-gradient(90deg, #1a2a4f, #a40f00);
    transition: width 0.4s ease;
    border-radius: 0 0 0 20px;
}

.equipo-def-frase:hover .equipo-def-linea {
    width: 100%;
}

/* ========== RESPONSIVE ========== */
@media (min-width: 992px) {
    .equipo-def-container {
        flex-direction: row;
        align-items: center;
        gap: 60px;
    }
    
    .equipo-def-imagen {
